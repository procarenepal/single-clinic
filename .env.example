# Firebase Configuration
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id
VITE_PASSWORD_RESET_DOMAIN=https://your-domain.netlify.app

# Appwrite Configuration
# Get these values from your Appwrite console at https://cloud.appwrite.io/console
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your-appwrite-project-id
VITE_APPWRITE_BUCKET_ID=clinic-assets

# Instructions:
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual credentials
# 3. For Appwrite:
#    - Create a project at https://cloud.appwrite.io/console
#    - Get your project ID from the project settings
#    - Create a storage bucket named "clinic-assets" (or use your preferred name)
#    - Update the bucket ID in the environment variable
# 4. For Firebase:
#    - Get your config from Firebase console project settings
#    - Replace all firebase values with your actual credentials
