        "@heroui/card": "^2.2.18",
        "@heroui/checkbox": "^2.3.18",
        "@heroui/chip": "^2.2.15",
        "@heroui/code": "2.2.14",
        "@heroui/divider": "^2.2.13",
        "@heroui/dropdown": "2.3.19",
        "@heroui/image": "^2.2.12",
        "@heroui/input": "2.4.19",
        "@heroui/kbd": "2.2.15",
        "@heroui/link": "2.2.16",
        "@heroui/navbar": "2.2.17",
        "@heroui/pagination": "^2.2.17",
        "@heroui/progress": "^2.2.15",
        "@heroui/react": "^2.7.8",
        "@heroui/select": "^2.4.19",
        "@heroui/snippet": "2.2.20",
        "@heroui/spinner": "^2.2.18",
        "@heroui/switch": "2.2.17",
        "@heroui/system": "2.4.15",
        "@heroui/theme": "2.4.15",
        "@heroui/toast": "^2.0.9",
        "@heroui/use-theme": "2.1.8",
        "@react-aria/visually-hidden": "3.8.22",
        "@react-types/shared": "3.29.0",
        "@types/crypto-js": "^4.2.2",
        "@types/jspdf": "^1.3.3",
        "appwrite": "^18.1.1",
        "axios": "^1.11.0",
        "chart.js": "^4.4.9",
        "clsx": "2.1.1",
        "crypto-js": "^4.2.0",
        "date-fns": "^4.1.0",
        "dotenv": "^16.5.0",
        "express": "^4.21.2",
        "firebase": "^11.7.3",
        "firebase-admin": "^13.4.0",
        "framer-motion": "11.15.0",
        "http-proxy-middleware": "^3.0.3",
