        "eslint-plugin-node": "11.1.0",
        "eslint-plugin-prettier": "5.2.1",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "5.2.0",
        "eslint-plugin-unused-imports": "4.1.4",
        "globals": "16.0.0",
        "postcss": "8.5.3",
        "prettier": "3.5.3",
        "terser": "^5.42.0",
        "typescript": "5.6.3",
        "vite": "5.2.0",
        "vite-tsconfig-paths": "4.3.2"
    }
