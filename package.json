{
    "name": "vite-template",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "build:suppress": "tsc --noEmit || true && vite build",
        "build:force": "vite build",
        "build:lenient": "tsc --project tsconfig.build.json || true && vite build",
        "build:no-check": "vite build --mode production",
        "lint": "eslint --fix",
        "preview": "vite preview",
        "initialize-system": "node scripts/initialize-system.cjs",
        "debug-permissions": "node scripts/debug-firebase-permissions.cjs",
        "initialize-admin": "node scripts/initialize-admin.js",
        "migrate:auto-assign": "tsx src/scripts/migrate-auto-assign.ts",
        "seed:pages": "tsx src/scripts/seed-pages.ts",
        "deploy:sms-function": "node scripts/deploy-sms-function.cjs",
        "configure:firebase-reset": "node scripts/configure-firebase-password-reset.js",
        "test:impersonation-sync": "node scripts/test-impersonation-sync.js",
        "rules:dev": "node scripts/switch-firestore-rules.js dev",
        "rules:prod": "node scripts/switch-firestore-rules.js prod",
        "railway:build": "npm run build && npm install --prefix sms-backend",
        "railway:start": "node railway-server.js",
        "railway:dev": "concurrently \"npm run dev\" \"cd sms-backend && npm run dev\"",
        "start": "node railway-server.js"
    },
    "npmrc": ".npmrc",
    "dependencies": {
        "@heroui/avatar": "^2.2.15",
